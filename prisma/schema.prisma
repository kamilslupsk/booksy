generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  image     String?
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider Provider?
  bookings Booking[]
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Provider {
  id            String   @id @default(cuid())
  userId        String   @unique
  slug          String   @unique
  displayName   String
  bio           String?  @db.Text
  address       String?
  city          String?
  phone         String?
  coverImage    String?
  galleryImages String[]
  category      String?
  isActive      Boolean  @default(false)
  onVacation    Boolean  @default(false)
  slotStepMin   Int      @default(30)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  services          Service[]
  availabilityRules AvailabilityRule[]
  vacationBlocks    VacationBlock[]
  bookings          Booking[]
  reviews           Review[]
  subscription      Subscription?
  referralLink      ReferralLink?
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  name        String
  description String?
  category    String?
  durationMin Int
  pricePln    Decimal  @db.Decimal(8, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  provider Provider  @relation(fields: [providerId], references: [id])
  bookings Booking[]
}

model AvailabilityRule {
  id         String @id @default(cuid())
  providerId String
  dayOfWeek  Int
  startTime  String
  endTime    String

  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, dayOfWeek])
}

model VacationBlock {
  id         String   @id @default(cuid())
  providerId String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  reason     String?

  provider Provider @relation(fields: [providerId], references: [id])
}

model Booking {
  id           String        @id @default(cuid())
  serviceId    String
  providerId   String
  clientId     String?
  guestName    String?
  guestPhone   String?
  startTime    DateTime
  endTime      DateTime
  status       BookingStatus @default(PENDING)
  depositPaid  Boolean       @default(false)
  cancelToken  String        @unique @default(cuid())
  notes        String?       @db.Text
  reviewSentAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  service  Service  @relation(fields: [serviceId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  client   User?    @relation(fields: [clientId], references: [id])
  review   Review?

  @@index([providerId, startTime])
  @@index([clientId])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  providerId String
  rating     Int
  content    String?  @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
}

model Subscription {
  id               String             @id @default(cuid())
  providerId       String             @unique
  status           SubscriptionStatus @default(TRIAL)
  trialEndsAt      DateTime
  currentPeriodEnd DateTime?
  stripeCustomerId String?
  stripeSubId      String?
  priceMonthlyPln  Decimal            @default(75) @db.Decimal(8, 2)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
}

model ReferralLink {
  id         String   @id @default(cuid())
  providerId String   @unique
  code       String   @unique
  balancePln Decimal  @default(0) @db.Decimal(8, 2)
  usedCount  Int      @default(0)
  createdAt  DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id])
}
